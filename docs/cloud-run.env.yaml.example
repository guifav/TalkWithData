# Non-secret Cloud Run runtime configuration.
# Copy this file outside the repository, replace every placeholder, and pass the
# copy to gcloud run deploy with --env-vars-file.
ALLOWED_AUTH_DOMAIN: "example.com"
NEXT_PUBLIC_ALLOWED_AUTH_DOMAIN: "example.com"
NEXT_PUBLIC_FIREBASE_API_KEY: "replace-with-public-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN: "replace-with-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID: "replace-with-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET: "replace-with-bucket-name"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID: "replace-with-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID: "replace-with-app-id"
FIREBASE_PROJECT_ID: "replace-with-project-id"
STORAGE_BUCKET_NAME: "replace-with-bucket-name"
APP_URL: "https://replace-with-service-url"
STORAGE_PROVIDER: "gcs"
AI_DEFAULT_PROVIDER: "anthropic"
TWD_READINESS_TIMEOUT_MS: "2000"
