# Environment variables for Talk With Data
# Copy this file to .env and fill in your values

# === Auth ===
# Your Google OAuth domain (e.g., yourdomain.com). Required. Fail-closed if not set.
ALLOWED_AUTH_DOMAIN=yourdomain.com

# Browser-side copy of ALLOWED_AUTH_DOMAIN. Client code cannot read
# ALLOWED_AUTH_DOMAIN, so set both to the same value. Must be set at build time.
NEXT_PUBLIC_ALLOWED_AUTH_DOMAIN=yourdomain.com

# === Firebase (client-side, exposed to browser) ===
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# === Firebase Admin (server-side) ===
FIREBASE_PROJECT_ID=your-project
# Optional legacy alias. Runtime storage uses STORAGE_BUCKET_NAME.
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Optional: SA key JSON for local dev. If not set, uses ADC (Application Default Credentials).
# SA_KEY_JSON=

# === Storage ===
# Firebase/GCS bucket name for HTML file storage
STORAGE_BUCKET_NAME=your-project-uploads

# === Database ===
# Prisma database URL for per-dashboard structured data. PostgreSQL is required.
DATABASE_URL=postgresql://user:password@localhost:5432/talkwithdata

# === Sessions ===
# Secret for embed token signing and fallback data-source inspection token signing.
# Generate with: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=generate-a-random-secret-here
# Optional dedicated secret for signed admin data-source inspection tokens.
# If unset, DASHBOARD_SESSION_SECRET is used; one of them is required in production.
# TWD_INSPECTION_TOKEN_SECRET=generate-a-random-secret-here

# === App URL ===
# Used for embed tokens and slug generation. Defaults to http://localhost:3000
APP_URL=http://localhost:3000

# === MCP (optional) ===
# Comma-separated list of allowed MCP server hosts. Empty = MCP disabled.
# MCP_ALLOWED_HOSTS=mcp.example.com,another-mcp.example.com
# MCP_API_KEY=your-mcp-api-key
# MCP_URL=https://mcp.example.com/api/mcp/full

# === Thumbnails (optional) ===
# Cloud Function URL for thumbnail generation. If not set, thumbnails are disabled.
# THUMBNAIL_FUNCTION_URL=
# THUMBNAIL_SECRET=

# === AI Provider ===
# At least one AI provider API key is required for AI features.
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# KIMI_API_KEY=
# GLM_API_KEY=
# Custom provider keys are stored server-side in Firestore users/{uid}.aiConfig

# Default AI provider and model (optional, defaults to anthropic)
# AI_DEFAULT_PROVIDER=anthropic
# AI_DEFAULT_MODEL=claude-sonnet-4-20250514

# === Storage Provider (optional, default: gcs) ===
# Set to "local" to use filesystem storage instead of GCS
STORAGE_PROVIDER=gcs

# Directory for uploaded files when STORAGE_PROVIDER=local. Default: /data/uploads
# docker-compose.yml sets it to /data/uploads inside the app_data volume.
# LOCAL_STORAGE_ROOT=/data/uploads

# === Node.js ===
# Requires Node.js 22+
