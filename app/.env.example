# Talk With Data local environment
# This is the single canonical template. Copy it to app/.env and replace the placeholders.

# =============================================================================
# PUBLIC CLIENT CONFIGURATION
# =============================================================================
# Every NEXT_PUBLIC_* value is exposed to browser code. Never put secrets here.
# The server reads these values at runtime and bootstraps only this allowlist to
# the browser, so the same container image can use different public config.

# Browser-side copy of ALLOWED_AUTH_DOMAIN. Set both values to the same domain.
NEXT_PUBLIC_ALLOWED_AUTH_DOMAIN=yourdomain.com

# Firebase Web App configuration. These identifiers are public by design.
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# =============================================================================
# SERVER-ONLY CONFIGURATION AND SECRETS
# =============================================================================
# Never add the NEXT_PUBLIC_ prefix to values in this section.

# === Auth ===
# Required. Authentication fails closed when this domain is missing.
ALLOWED_AUTH_DOMAIN=yourdomain.com

# === Firebase Admin ===
FIREBASE_PROJECT_ID=your-project
# Optional legacy alias. Runtime storage uses STORAGE_BUCKET_NAME.
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Optional service account JSON for local development. If unset, uses ADC.
# SA_KEY_JSON=

# === Storage ===
# Dashboard storage provider: gcs (default) or local.
STORAGE_PROVIDER=gcs
# Required only for STORAGE_PROVIDER=gcs.
STORAGE_BUCKET_NAME=your-project-uploads
# Persistent directory used only for STORAGE_PROVIDER=local.
# Docker Compose mounts /data from its app_data named volume.
# LOCAL_STORAGE_ROOT=/data/uploads

# === Database ===
# PostgreSQL is required for Prisma and per-dashboard structured data.
# Docker Compose overrides this host URL with its internal `db` service URL.
DATABASE_URL=postgresql://user:password@localhost:5432/talkwithdata

# === Sessions ===
# Required for embed token signing and fallback data-source inspection tokens.
# Generate with: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=generate-a-random-secret-here
# Optional dedicated secret for signed admin data-source inspection tokens.
# TWD_INSPECTION_TOKEN_SECRET=generate-a-random-secret-here

# === Data sources ===
# 32-byte base64 AES-256-GCM key for credentials stored encrypted at rest.
# Required in production when a source stores a credential.
# Generate with: openssl rand -base64 32
# TWD_CREDENTIAL_ENC_KEY=generate-a-32-byte-base64-key
# Organization id tagged onto sources created through the admin UI.
# TWD_ORG_ID=
# Query guardrails. Defaults are used when these values are unset.
# TWD_QUERY_TIMEOUT_MS=10000
# TWD_MAX_ROWS=1000
# TWD_ENGINE_LRU_BYTES=67108864

# === AI providers ===
# At least one provider API key is required for AI features.
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# KIMI_API_KEY=
# GLM_API_KEY=
# 32-byte base64 AES-256-GCM key for custom provider keys in the admin UI.
# Required in production before saving custom provider keys.
# Generate with: openssl rand -base64 32
# TWD_AI_CONFIG_ENC_KEY=generate-a-32-byte-base64-key
# Temporary compatibility flag. Keep unset after running the migration.
# TWD_AI_CONFIG_LEGACY_READ=1
# Optional provider and model defaults.
# AI_DEFAULT_PROVIDER=anthropic
# AI_DEFAULT_MODEL=claude-sonnet-4-20250514

# === App URL ===
# Used for links and token generation. Defaults to http://localhost:3000.
APP_URL=http://localhost:3000

# === Observability ===
# Minimum structured log level: info (default), warn, or error.
# TWD_LOG_LEVEL=info

# === MCP (optional) ===
# Comma-separated allowlist. Empty means MCP calls are disabled.
# MCP_ALLOWED_HOSTS=mcp.example.com,another-mcp.example.com
# MCP_API_KEY=your-mcp-api-key
# MCP_URL=https://mcp.example.com/api/mcp/full

# === Thumbnails (optional) ===
# THUMBNAIL_FUNCTION_URL=
# THUMBNAIL_SECRET=

# Node.js 22 or newer is required.
