{
  "name": "talk-with-data",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guifav/TalkWithData.git",
    "directory": "app"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.10",
    "@hono/node-server": "1.19.13"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:migrations": "../scripts/test-migrations.sh",
    "test:runtime-config-container": "../scripts/test-runtime-firebase-container.sh",
    "test:firestore-rules": "REQUIRE_FIRESTORE_EMULATOR=1 vitest run src/lib/__tests__/firestore-rules.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "../scripts/run-e2e.sh",
    "test:e2e:run": "playwright test",
    "test:e2e:screenshots": "TWD_CAPTURE_README_SCREENSHOTS=1 playwright test e2e/readme-screenshots.spec.ts",
    "capture:readme-screenshots": "TWD_E2E_NPM_SCRIPT=test:e2e:screenshots ../scripts/run-e2e.sh",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "audit:roles": "tsx scripts/audit-role-access.ts",
    "backfill:searchable": "tsx scripts/backfill-searchable.ts",
    "migrate:ai-config-secrets": "tsx scripts/migrate-ai-config-secrets.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "@google-cloud/storage": "^7.21.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "adm-zip": "^0.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "exceljs": "^4.4.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^13.6.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "node-sql-parser": "5.4.0",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.0",
    "vitest": "^4.1.4"
  }
}
